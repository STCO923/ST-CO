# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# LLM — Groq est GRATUIT (défaut), Anthropic est payant (meilleur)
# LLM_PROVIDER=groq (par défaut) ou anthropic
LLM_PROVIDER=groq

# Groq — GRATUIT (console.groq.com → API Keys)
# Utilisé pour le LLM (Llama 3.3 70B) ET la transcription vocale (Whisper)
GROQ_API_KEY=your_groq_api_key

# Anthropic — PAYANT (optionnel, meilleure qualité)
# ANTHROPIC_API_KEY=sk-ant-your_key

# Supabase
SUPABASE_URL=https://zmoqurdxsayqsfyoujhu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Sheets (optionnel)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Server
PORT=3000
WEBHOOK_URL=https://your-railway-domain.up.railway.app

# Audit quotidien (heure d'envoi, défaut: 7h)
# DAILY_AUDIT_HOUR=7
